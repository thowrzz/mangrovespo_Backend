# ──────────────────────────────────────────
# MangroveSpot Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to Git
# ──────────────────────────────────────────

# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Dev  → leave as sqlite:///db.sqlite3 (default, no change needed)
# Prod → postgresql://mangrovespot_user:password@localhost:5432/mangrovespot_db
DATABASE_URL=sqlite:///db.sqlite3

# CORS — origins allowed to call the API
# Dev  → http://localhost:3000,http://localhost:3001
# Prod → https://mangrovespot.in,https://admin.mangrovespot.in
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Razorpay
# Dev  → use rzp_test_ keys
# Prod → use rzp_live_ keys
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_secret_here

# Cloudinary (same for dev and prod)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SendGrid (same for dev and prod)
SENDGRID_API_KEY=SG.your_key_here
DEFAULT_FROM_EMAIL=bookings@mangrovespot.in
ADMIN_EMAIL=mangrovespot.care@gmail.com

# Redis / Celery
# Dev  → redis://localhost:6379/0 (install Redis locally or use Docker)
# Prod → redis://localhost:6379/0 (Redis on same VPS)
REDIS_URL=redis://localhost:6379/0

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000
